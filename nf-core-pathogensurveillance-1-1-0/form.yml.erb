---
cluster: "pax"
form_header: |
  > **Saved form values**
  >
  > This app automatically saves your form inputs between sessions.
  >
  > To clear the saved form values for this app, use the [cache reset utility](/pun/sys/cache_reset/?app_slug=nf-core-pathogensurveillance-1-1-0&return_url=/pun/sys/dashboard/batch_connect/sys/nf-core-pathogensurveillance-1-1-0/session_contexts/new).

attributes:
  bc_num_hours:
    label: Number of hours
    widget: number_field
    value: 8
    min: 1
    step: 1
    help: Requested walltime for the launch job.

  bc_email_on_started:
    label: Email when job starts
    widget: check_box
    checked_value: 1
    unchecked_value: 0
    help: Send an email notification when the Open OnDemand launch job starts.

  nextflow_version:
    label: Nextflow version
    widget: select
    options:
      - ["26.04.3", "26.04.3"]
      - ["25.10.3", "25.10.3"]
      - ["25.04.0", "25.04.0"]
    help: Use an older Nextflow version when running previous nf-core pipeline releases.

<%= File.read("/etc/ood/config/apps/dashboard/batch_connect/partials/cpu_partition.yml").indent(2) %>

  num_cores:
    label: Number of cores
    widget: number_field
    value: 4
    min: 1
    step: 1
    help: CPU count used for single-node local execution.

  num_memory:
    label: Amount of memory (GB)
    widget: number_field
    value: 8
    min: 1
    step: 1
    help: Memory requested for single-node local execution.

  executor:
    label: Which Nextflow executor should be used?
    widget: select
    options:
      - ["slurm", "slurm", data-hide-partition: true, data-hide-num-cores: true, data-hide-num-memory: true]
      - ["local", "local"]
    help: |
      With `slurm`, the pipeline uses its configured scheduler profile.
      With `local`, tasks run on the submitted node using a generated config.

  workdir:
    label: Working directory
    widget: path_selector
    required: false
    directory: "/cluster/tufts"
    favorites:
      - "/cluster/tufts"
    help: Directory where the Nextflow launch should run.

  resume:
    label: Resume previous run
    widget: check_box
    checked_value: 1
    unchecked_value: 0
    help: Resume a previous run if a matching Nextflow work directory exists.


  input_output_options:
    label: 'Input/output options'
    widget: 'check_box'
    html_options:
      data:
        hide-input-when-un-checked: true
        hide-max_parallel_downloads-when-un-checked: true
        hide-reference_data-when-un-checked: true
        hide-outdir-when-un-checked: true
        hide-temp_dir-when-un-checked: true
        hide-data_dir-when-un-checked: true
        hide-multiqc_title-when-un-checked: true
        hide-bakta_db-when-un-checked: true
        hide-download_bakta_db-when-un-checked: true
        hide-bakta_db_type-when-un-checked: true
    help: 'Define where the pipeline should find input data and save output data.'

  input:
    label: 'input'
    required: true
    widget: path_selector
    directory: "<%= ENV.fetch('NF2OOD_DEFAULT_DIRECTORY', ENV.fetch('HOME', '/')) %>"
    favorites:
      - "<%= ENV.fetch('HOME', '/') %>"
    help: 'Path to comma/tab-separated file containing information about samples.'

  max_parallel_downloads:
    label: 'max_parallel_downloads'
    widget: number_field
    step: 1
    help: 'Maximum number of parallel downloads allowed for certain processes. This can be set to control the number of concurrent downloads to avoid overloading servers or hitting API rate limits.'

  reference_data:
    label: 'reference_data'
    widget: path_selector
    directory: "<%= ENV.fetch('NF2OOD_DEFAULT_DIRECTORY', ENV.fetch('HOME', '/')) %>"
    favorites:
      - "<%= ENV.fetch('HOME', '/') %>"
    help: 'Path to comma-separated file containing information about references.'

  outdir:
    label: 'outdir'
    required: true
    widget: path_selector
    directory: "<%= ENV.fetch('NF2OOD_DEFAULT_DIRECTORY', ENV.fetch('HOME', '/')) %>"
    favorites:
      - "<%= ENV.fetch('HOME', '/') %>"
    help: 'The output directory where the results will be saved. You have to use absolute paths to storage if running on Cloud infrastructure.'

  temp_dir:
    label: 'temp_dir'
    widget: path_selector
    directory: "<%= ENV.fetch('NF2OOD_DEFAULT_DIRECTORY', ENV.fetch('HOME', '/')) %>"
    favorites:
      - "<%= ENV.fetch('HOME', '/') %>"
    help: 'The location to save temporary files for processes. This is only used for some processes that produce large temporary files such as PICARD_SORTSAM.'

  data_dir:
    label: 'data_dir'
    widget: path_selector
    value: 'path_surveil_data'
    directory: "<%= ENV.fetch('NF2OOD_DEFAULT_DIRECTORY', ENV.fetch('HOME', '/')) %>"
    favorites:
      - "<%= ENV.fetch('HOME', '/') %>"
    help: 'The location to save downloaded files for later use. This is seperate from the cached data (usually stored in the ''work'' directory), so that the cache can be cleared without having to repeat many large downloads.'

  multiqc_title:
    label: 'multiqc_title'
    widget: text_field
    help: 'MultiQC report title. Printed as page header, used for filename if not otherwise specified.'

  bakta_db:
    label: 'bakta_db'
    widget: path_selector
    directory: "<%= ENV.fetch('NF2OOD_DEFAULT_DIRECTORY', ENV.fetch('HOME', '/')) %>"
    favorites:
      - "<%= ENV.fetch('HOME', '/') %>"
    help: 'The path to the Bakta database folder. This or --download_bakta_db must be included.'

  download_bakta_db:
    label: 'download_bakta_db'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    help: 'Download the database required for running Bakta. This or --bakta_db must be included. For more information, see: https://github.com/oschwengers/bakta?tab=readme-ov-file#database-download'

  bakta_db_type:
    label: 'bakta_db_type'
    widget: text_field
    value: 'light'
    help: 'Which type of the Bakta database to download. Must be ''light'' (~2Gb) or ''full'' (~40Gb).'

  analysis_parameters:
    label: 'Analysis parameters'
    widget: 'check_box'
    html_options:
      data:
        hide-max_samples-when-un-checked: true
        hide-max_depth-when-un-checked: true
        hide-only_latin_binomial_refs-when-un-checked: true
        hide-allow_non_refseq-when-un-checked: true
        hide-allow_unannotated-when-un-checked: true
        hide-allow_atypical_refs-when-un-checked: true
        hide-n_ref_strains-when-un-checked: true
        hide-n_ref_species-when-un-checked: true
        hide-n_ref_genera-when-un-checked: true
        hide-n_ref_closest-when-un-checked: true
        hide-n_ref_closest_named-when-un-checked: true
        hide-n_ref_context-when-un-checked: true
        hide-phylo_min_genes-when-un-checked: true
        hide-phylo_max_genes-when-un-checked: true
        hide-ref_min_ani-when-un-checked: true
        hide-min_bases_to_assemble-when-un-checked: true
        hide-max_variants-when-un-checked: true
        hide-cpu_scale-when-un-checked: true
        hide-skip_core_phylogeny-when-un-checked: true
    help: 'Parameters that modify the analysis done by the pipeline.'

  max_samples:
    label: 'max_samples'
    widget: number_field
    value: 1000
    step: 1
    help: 'Maximum number of samples to analyze. The first n samples will be used.'

  max_depth:
    label: 'max_depth'
    widget: number_field
    value: 100
    step: 1
    help: 'Maximum depth of reads to be used for all analyses. Samples with more reads are subsampled to this depth.'

  only_latin_binomial_refs:
    label: 'only_latin_binomial_refs'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    value: false
    help: 'When selecting references automatically, only consider references with names that appear to be standard latin bionomials (i.e. no numbers or symbols in the first two words).'

  allow_non_refseq:
    label: 'allow_non_refseq'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    value: false
    help: 'When selecting references automatically, allow assemblies not in RefSeq.'

  allow_unannotated:
    label: 'allow_unannotated'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    value: false
    help: 'When selecting references automatically, allow assemblies that do not have annotations. The pipeline will attempt to annotate these references as needed.'

  allow_atypical_refs:
    label: 'allow_atypical_refs'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    value: false
    help: 'When selecting references automatically, allow assemblies that NCBI considers atypical.'

  n_ref_strains:
    label: 'n_ref_strains'
    widget: number_field
    step: 1
    help: 'The maximum number/percentage of references representing unique subspecies to download from RefSeq for each species predicited to be in each sample. Samples with similar initial indentifications will usually use the same references, so the total number of references downloaded for a goup of samples will depend on the taxonomic diversity of the samples.'

  n_ref_species:
    label: 'n_ref_species'
    widget: number_field
    step: 1
    help: 'The maximum number/percentage of references representing unique species to download from RefSeq for each genus predicited to be in each sample. Samples with similar initial indentifications will usually use the same references, so the total number of references downloaded for a goup of samples will depend on the taxonomic diversity of the samples.'

  n_ref_genera:
    label: 'n_ref_genera'
    widget: number_field
    step: 1
    help: 'The maximum number/percentage of references representing unique genera to download from RefSeq for each family predicited to be in each sample. Samples with similar initial indentifications will usually use the same references, so the total number of references downloaded for a goup of samples will depend on the taxonomic diversity of the samples.'

  n_ref_closest:
    label: 'n_ref_closest'
    widget: number_field
    value: 2
    step: 1
    help: 'The number of references most similar to each sample based on estimated ANI to include in phyogenetic anlyses.'

  n_ref_closest_named:
    label: 'n_ref_closest_named'
    widget: number_field
    value: 1
    step: 1
    help: 'Same as the ''n_ref_closest'' option except that it only applies to referneces with what apppear to be standard latin binomaial names (i.e. two words with no numbers or symbols). This is intended to ensure that a refernece with an informative name is present even if it is not the most similar.'

  n_ref_context:
    label: 'n_ref_context'
    widget: number_field
    value: 5
    step: 1
    help: 'The number of references representing the entire range of ANI relative to each sample. These are meant to provide context for more similar references. For a group of samples, the fewest total references will be selected that satisify this count for each sample.'

  phylo_min_genes:
    label: 'phylo_min_genes'
    widget: number_field
    value: 10
    step: 1
    help: 'The minimum number of genes needed to conduct a core gene phylogeny. Samples and references will be removed (as allowed by the `min_core_samps` and `min_core_refs` options) until this minimum is met.'

  phylo_max_genes:
    label: 'phylo_max_genes'
    widget: number_field
    value: 500
    step: 1
    help: 'The maximum number of genes used to conduct a core gene phylogeny.'

  ref_min_ani:
    label: 'ref_min_ani'
    widget: number_field
    value: 0.95
    step: 1
    help: 'The minimum ANI between a sample and potential reference for that reference to be used for mapping reads from that sample. To force all the samples in a report group to use the same reference, set this value very low.'

  min_bases_to_assemble:
    label: 'min_bases_to_assemble'
    widget: number_field
    value: 100000
    step: 1
    help: 'The minimum number of bases after quality filtering needed to attempt an genome assembly. Samples with few than this amount of bases will be excluded from further analysis.'

  max_variants:
    label: 'max_variants'
    widget: number_field
    value: 100000
    step: 1
    help: 'The maximum number of variants to use for the SNP tree and minimum spanning nextwork produced by the variant analysis. The first N variants are used when more than N are available.'

  cpu_scale:
    label: 'cpu_scale'
    widget: number_field
    value: 1.0
    step: 1
    help: 'A scaling factor to adjust the number of CPUs used by multithreaded processes. The number of CPUs for each process will be multiplied by this value and rounded to the nearest integer (minimum 1).'

  skip_core_phylogeny:
    label: 'skip_core_phylogeny'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    value: false
    help: 'Skip the core genome phylogeny analysis. This will not affect downstream processes like MultiQC and the main report.'

form:
  - bc_num_hours
  - nextflow_version
  - executor
  - partition
  - num_cores
  - num_memory
  - workdir
  - input_output_options
  - input
  - max_parallel_downloads
  - reference_data
  - outdir
  - temp_dir
  - data_dir
  - multiqc_title
  - bakta_db
  - download_bakta_db
  - bakta_db_type
  - analysis_parameters
  - max_samples
  - max_depth
  - only_latin_binomial_refs
  - allow_non_refseq
  - allow_unannotated
  - allow_atypical_refs
  - n_ref_strains
  - n_ref_species
  - n_ref_genera
  - n_ref_closest
  - n_ref_closest_named
  - n_ref_context
  - phylo_min_genes
  - phylo_max_genes
  - ref_min_ani
  - min_bases_to_assemble
  - max_variants
  - cpu_scale
  - skip_core_phylogeny
  - resume
  - bc_email_on_started
