<%
require "json"

to_bool = lambda do |value|
  case value
  when true, false
    value
  when String
    normalized = value.strip.downcase
    next true if %w[true 1 yes y on].include?(normalized)
    next false if %w[false 0 no n off].include?(normalized)
    value
  else
    value
  end
end

to_number = lambda do |value|
  case value
  when Integer, Float
    value
  when String
    stripped = value.strip
    next value if stripped.empty?
    next stripped.to_i if stripped.match?(/\A[+-]?\d+\z/)
    next stripped.to_f if stripped.match?(/\A[+-]?(?:\d+\.?\d*|\.\d+)(?:[eE][+-]?\d+)?\z/)
    value
  else
    value
  end
end

params = {
    "qc_only": to_bool.call(context.qc_only),
    "skip_assembly": to_bool.call(context.skip_assembly),
    "input": context.input,
    "outdir": context.outdir,
    "transcript_fasta": context.transcript_fasta,
    "multiqc_title": context.multiqc_title,
    "adapter_fasta": context.adapter_fasta,
    "save_trimmed_fail": to_bool.call(context.save_trimmed_fail),
    "save_merged": to_bool.call(context.save_merged),
    "skip_fastp": to_bool.call(context.skip_fastp),
    "skip_fastqc": to_bool.call(context.skip_fastqc),
    "extra_fastp_args": context.extra_fastp_args,
    "remove_ribo_rna": to_bool.call(context.remove_ribo_rna),
    "ribo_database_manifest": context.ribo_database_manifest,
    "save_non_ribo_reads": to_bool.call(context.save_non_ribo_reads),
    "assemblers": context.assemblers,
    "extra_trinity_args": context.extra_trinity_args,
    "soft_filtered_transcripts": to_bool.call(context.soft_filtered_transcripts),
    "hard_filtered_transcripts": to_bool.call(context.hard_filtered_transcripts),
    "ss": context.ss,
    "extra_tr2aacds_args": context.extra_traacds2_args,
    "busco_mode": context.busco_mode,
    "busco_lineage": context.busco_lineage,
    "busco_lineages_path": context.busco_lineages_path,
    "busco_config": context.busco_config,
    "fasta": context.fasta,
    "gtf": context.gtf,
    "transrate_reference": context.transrate_reference,
    "lib_type": context.lib_type,
    "igenomes_base": context.igenomes_base,
    "igenomes_ignore": to_bool.call(context.igenomes_ignore)
}

params.reject! { |_k, v| v.is_a?(String) && v.strip.empty? }
%><%= JSON.pretty_generate(params) %>
