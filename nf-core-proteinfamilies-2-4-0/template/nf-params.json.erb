<%
require "json"

to_bool = lambda do |value|
  case value
  when true, false
    value
  when String
    normalized = value.strip.downcase
    next true if %w[true 1 yes y on].include?(normalized)
    next false if %w[false 0 no n off].include?(normalized)
    value
  else
    value
  end
end

to_number = lambda do |value|
  case value
  when Integer, Float
    value
  when String
    stripped = value.strip
    next value if stripped.empty?
    next stripped.to_i if stripped.match?(/\A[+-]?\d+\z/)
    next stripped.to_f if stripped.match?(/\A[+-]?(?:\d+\.?\d*|\.\d+)(?:[eE][+-]?\d+)?\z/)
    value
  else
    value
  end
end

params = {
    "input": context.input,
    "outdir": context.outdir,
    "multiqc_title": context.multiqc_title,
    "skip_preprocessing": to_bool.call(context.skip_preprocessing),
    "min_seq_length": to_number.call(context.min_seq_length),
    "max_seq_length": to_number.call(context.max_seq_length),
    "remove_duplicates_on_sequence": to_bool.call(context.remove_duplicates_on_sequence),
    "save_update_families_pre_clipped_fasta": to_bool.call(context.save_update_families_pre_clipped_fasta),
    "save_update_families_clipped_fasta": to_bool.call(context.save_update_families_clipped_fasta),
    "save_mmseqs_db": to_bool.call(context.save_mmseqs_db),
    "clustering_tool": context.clustering_tool,
    "cluster_seq_identity": to_number.call(context.cluster_seq_identity),
    "cluster_coverage": to_number.call(context.cluster_coverage),
    "cluster_cov_mode": to_number.call(context.cluster_cov_mode),
    "save_mmseqs_clustering": to_bool.call(context.save_mmseqs_clustering),
    "cluster_size_threshold": to_number.call(context.cluster_size_threshold),
    "save_mmseqs_chunked_fasta": to_bool.call(context.save_mmseqs_chunked_fasta),
    "alignment_tool": context.alignment_tool,
    "clipkit_out_format": context.clipkit_out_format,
    "trim_ends_only": to_bool.call(context.trim_ends_only),
    "gap_threshold": to_number.call(context.gap_threshold),
    "hmmsearch_evalue_cutoff": to_number.call(context.hmmsearch_evalue_cutoff),
    "save_hmmsearch_results": to_bool.call(context.save_hmmsearch_results),
    "hmmsearch_query_length_threshold": to_number.call(context.hmmsearch_query_length_threshold),
    "save_hmmsearch_filtered_fasta": to_bool.call(context.save_hmmsearch_filtered_fasta),
    "hmmsearch_family_redundancy_length_threshold": to_number.call(context.hmmsearch_family_redundancy_length_threshold),
    "hmmsearch_family_similarity_length_threshold": to_number.call(context.hmmsearch_family_similarity_length_threshold),
    "save_non_redundant_fams_fasta": to_bool.call(context.save_non_redundant_fams_fasta),
    "cluster_seq_identity_for_redundancy": to_number.call(context.cluster_seq_identity_for_redundancy),
    "cluster_coverage_for_redundancy": to_number.call(context.cluster_coverage_for_redundancy),
    "cluster_cov_mode_for_redundancy": to_number.call(context.cluster_cov_mode_for_redundancy),
    "save_non_redundant_seqs_fasta": to_bool.call(context.save_non_redundant_seqs_fasta)
}

params.reject! { |_k, v| v.is_a?(String) && v.strip.empty? }
%><%= JSON.pretty_generate(params) %>
