<%
require "json"

to_bool = lambda do |value|
  case value
  when true, false
    value
  when String
    normalized = value.strip.downcase
    next true if %w[true 1 yes y on].include?(normalized)
    next false if %w[false 0 no n off].include?(normalized)
    value
  else
    value
  end
end

to_number = lambda do |value|
  case value
  when Integer, Float
    value
  when String
    stripped = value.strip
    next value if stripped.empty?
    next stripped.to_i if stripped.match?(/\A[+-]?\d+\z/)
    next stripped.to_f if stripped.match?(/\A[+-]?(?:\d+\.?\d*|\.\d+)(?:[eE][+-]?\d+)?\z/)
    value
  else
    value
  end
end

params = {
    "input": context.input,
    "outdir": context.outdir,
    "multiqc_title": context.multiqc_title,
    "barcode_whitelist": context.barcode_whitelist,
    "aligner": context.aligner,
    "protocol": context.protocol,
    "skip_multiqc": to_bool.call(context.skip_multiqc),
    "skip_fastqc": to_bool.call(context.skip_fastqc),
    "skip_cellbender": to_bool.call(context.skip_cellbender),
    "skip_emptydrops": to_bool.call(context.skip_emptydrops),
    "genome": context.genome,
    "fasta": context.fasta,
    "igenomes_ignore": to_bool.call(context.igenomes_ignore),
    "transcript_fasta": context.transcript_fasta,
    "gtf": context.gtf,
    "save_reference": to_bool.call(context.save_reference),
    "save_align_intermeds": to_bool.call(context.save_align_intermeds),
    "igenomes_base": context.igenomes_base,
    "txp2gene": context.txpgene2,
    "simpleaf_index": context.simpleaf_index,
    "simpleaf_umi_resolution": context.simpleaf_umi_resolution,
    "star_index": context.star_index,
    "star_ignore_sjdbgtf": context.star_ignore_sjdbgtf,
    "seq_center": context.seq_center,
    "star_feature": context.star_feature,
    "kallisto_index": context.kallisto_index,
    "kb_t1c": context.kb_tc1,
    "kb_t2c": context.kb_tc2,
    "kb_workflow": context.kb_workflow,
    "cellranger_index": context.cellranger_index,
    "skip_cellranger_renaming": to_bool.call(context.skip_cellranger_renaming),
    "motifs": context.motifs,
    "cellrangerarc_config": context.cellrangerarc_config,
    "cellrangerarc_reference": context.cellrangerarc_reference,
    "cellranger_vdj_index": context.cellranger_vdj_index,
    "skip_cellrangermulti_vdjref": to_bool.call(context.skip_cellrangermulti_vdjref),
    "gex_frna_probe_set": context.gex_frna_probe_set,
    "gex_target_panel": context.gex_target_panel,
    "gex_cmo_set": context.gex_cmo_set,
    "fb_reference": context.fb_reference,
    "vdj_inner_enrichment_primers": context.vdj_inner_enrichment_primers,
    "gex_barcode_sample_assignment": context.gex_barcode_sample_assignment,
    "cellranger_multi_barcodes": context.cellranger_multi_barcodes
}

params.reject! { |_k, v| v.is_a?(String) && v.strip.empty? }
%><%= JSON.pretty_generate(params) %>
