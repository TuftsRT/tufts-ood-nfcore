---
cluster: "pax"
form_header: |
  <!-- NF2OOD_BANNER_START -->
  <div style="text-align: center; margin-bottom: 20px;">
    <img src="https://raw.githubusercontent.com/nf-core/sarek/3.8.1//docs/images/sarek_workflow.png"
         alt="nf-core-sarek"
         style="max-width: 600px; max-height: 600px; height: auto; margin-bottom: 10px;">
  </div>
  <!-- NF2OOD_BANNER_END -->

  > **Saved form values**
  >
  > This app automatically saves your form inputs between sessions.
  >
  > To clear the saved form values for this app, use the [cache reset utility](/pun/sys/cache_reset/?app_slug=nf-core-sarek-3-8-1&return_url=/pun/sys/dashboard/batch_connect/sys/nf-core-sarek-3-8-1/session_contexts/new).

attributes:
  bc_num_hours:
    label: Number of hours
    widget: number_field
    value: 8
    min: 1
    step: 1
    help: Requested walltime for the launch job.

<%= File.read("/etc/ood/config/apps/dashboard/batch_connect/partials/cpu_partition.yml").indent(2) %>

  num_cores:
    label: Number of cores
    widget: number_field
    value: 4
    min: 1
    step: 1
    help: CPU count used for single-node local execution.

  num_memory:
    label: Amount of memory (GB)
    widget: number_field
    value: 8
    min: 1
    step: 1
    help: Memory requested for single-node local execution.

  executor:
    label: Which Nextflow executor should be used?
    widget: select
    options:
      - ["slurm", "slurm", data-hide-partition: true, data-hide-num-cores: true, data-hide-num-memory: true]
      - ["local", "local"]
    help: |
      With `slurm`, the pipeline uses its configured scheduler profile.
      With `local`, tasks run on the submitted node using a generated config.

  workdir:
    label: Working directory
    widget: path_selector
    required: false
    directory: "/cluster/tufts"
    favorites:
      - "/cluster/tufts"
    help: Directory where the Nextflow launch should run.

  resume:
    label: Resume previous run
    widget: check_box
    checked_value: 1
    unchecked_value: 0
    help: Resume a previous run if a matching Nextflow work directory exists.

  tower_access_token:
    widget: text_field
    required: false
    label: Nextflow Tower access token (optional)
    help: |
      Optional Seqera Platform or Tower access token used with `-with-tower`.


  input_output_options:
    label: 'Input/output options'
    widget: 'check_box'
    html_options:
      data:
        hide-input-when-un-checked: true
        hide-step-when-un-checked: true
        hide-outdir-when-un-checked: true
    help: 'Define where the pipeline should find input data and save output data.'

  input:
    label: 'input'
    widget: path_selector
    directory: "<%= ENV.fetch('NF2OOD_DEFAULT_DIRECTORY', ENV.fetch('HOME', '/')) %>"
    favorites:
      - "<%= ENV.fetch('HOME', '/') %>"
    help: 'Path to comma-separated file containing information about the samples in the experiment.'

  step:
    label: 'step'
    required: true
    widget: select
    options:
      - ['mapping', 'mapping']
      - ['markduplicates', 'markduplicates']
      - ['prepare_recalibration', 'prepare_recalibration']
      - ['recalibrate', 'recalibrate']
      - ['variant_calling', 'variant_calling']
      - ['annotate', 'annotate']
    help: 'Starting step'

  outdir:
    label: 'outdir'
    required: true
    widget: path_selector
    directory: "<%= ENV.fetch('NF2OOD_DEFAULT_DIRECTORY', ENV.fetch('HOME', '/')) %>"
    favorites:
      - "<%= ENV.fetch('HOME', '/') %>"
    help: 'The output directory where the results will be saved. You have to use absolute paths to storage on Cloud infrastructure.'

  main_options:
    label: 'Main options'
    widget: 'check_box'
    html_options:
      data:
        hide-split_fastq-when-un-checked: true
        hide-nucleotides_per_second-when-un-checked: true
        hide-intervals-when-un-checked: true
        hide-no_intervals-when-un-checked: true
        hide-wes-when-un-checked: true
        hide-tools-when-un-checked: true
        hide-skip_tools-when-un-checked: true
    help: 'Most common options used for the pipeline'

  split_fastq:
    label: 'split_fastq'
    widget: number_field
    value: 50000000
    step: 1
    help: 'Specify how many reads each split of a FastQ file contains. Set 0 to turn off splitting at all.'

  nucleotides_per_second:
    label: 'nucleotides_per_second'
    widget: number_field
    value: 200000
    step: 1
    help: 'Estimate interval size.'

  intervals:
    label: 'intervals'
    widget: path_selector
    directory: "<%= ENV.fetch('NF2OOD_DEFAULT_DIRECTORY', ENV.fetch('HOME', '/')) %>"
    favorites:
      - "<%= ENV.fetch('HOME', '/') %>"
    help: 'Path to target bed file in case of whole exome or targeted sequencing or intervals file.'

  no_intervals:
    label: 'no_intervals'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    help: 'Disable usage of intervals.'

  wes:
    label: 'wes'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    help: 'Enable when exome or panel data is provided.'

  tools:
    label: 'tools'
    widget: text_field
    help: 'Tools to use for contamination removal, duplicate marking, variant calling and/or for annotation.'

  skip_tools:
    label: 'skip_tools'
    widget: text_field
    help: 'Disable specified tools.'

  fastq_preprocessing:
    label: 'FASTQ Preprocessing'
    widget: 'check_box'
    html_options:
      data:
        hide-trim_fastq-when-un-checked: true
        hide-clip_r1-when-un-checked: true
        hide-clip_r2-when-un-checked: true
        hide-three_prime_clip_r1-when-un-checked: true
        hide-three_prime_clip_r2-when-un-checked: true
        hide-trim_nextseq-when-un-checked: true
        hide-length_required-when-un-checked: true
        hide-save_trimmed-when-un-checked: true
        hide-save_split_fastqs-when-un-checked: true
    help: 'Trim fastq file or handle UMIs'

  trim_fastq:
    label: 'trim_fastq'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    help: 'Run FastP for read trimming'

  clip_r1:
    label: 'clip_r1'
    widget: number_field
    value: 0
    step: 1
    help: 'Remove bp from the 5'' end of read 1'

  clip_r2:
    label: 'clip_r2'
    widget: number_field
    value: 0
    step: 1
    help: 'Remove bp from the 5'' end of read 2'

  three_prime_clip_r1:
    label: 'three_prime_clip_r1'
    widget: number_field
    value: 0
    step: 1
    help: 'Remove bp from the 3'' end of read 1'

  three_prime_clip_r2:
    label: 'three_prime_clip_r2'
    widget: number_field
    value: 0
    step: 1
    help: 'Remove bp from the 3'' end of read 2'

  trim_nextseq:
    label: 'trim_nextseq'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    help: 'Removing poly-G tails.'

  length_required:
    label: 'length_required'
    widget: number_field
    value: 15
    step: 1
    help: 'Minimum length of reads to keep'

  save_trimmed:
    label: 'save_trimmed'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    help: 'Save trimmed FastQ file intermediates.'

  save_split_fastqs:
    label: 'save_split_fastqs'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    help: 'If set, publishes split FASTQ files. Intended for testing purposes.'

  umi_processing:
    label: 'Unique Molecular Identifiers'
    widget: 'check_box'
    html_options:
      data:
        hide-umi_read_structure-when-un-checked: true
        hide-group_by_umi_strategy-when-un-checked: true
        hide-umi_in_read_header-when-un-checked: true
        hide-umi_location-when-un-checked: true
        hide-umi_length-when-un-checked: true
        hide-umi_base_skip-when-un-checked: true
        hide-umi_tag-when-un-checked: true
        hide-bbsplit_fasta_list-when-un-checked: true
        hide-bbsplit_index-when-un-checked: true
        hide-save_bbsplit_reads-when-un-checked: true
    help: 'Parameters related to the handling of Unique Molecular Identifiers (UMIs)'

  umi_read_structure:
    label: 'umi_read_structure'
    widget: text_field
    help: 'Specify UMI read structure for fgbio UMI consensus read generation'

  group_by_umi_strategy:
    label: 'group_by_umi_strategy'
    widget: select
    options:
      - ['Adjacency', 'Adjacency']
      - ['Identity', 'Identity']
      - ['Edit', 'Edit']
      - ['Paired', 'Paired']
    help: 'Default strategy for fgbio UMI-based consensus read generation'

  umi_in_read_header:
    label: 'umi_in_read_header'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    help: 'Move UMIs from fastq read headers to a tag prior to deduplication.'

  umi_location:
    label: 'umi_location'
    widget: select
    options:
      - ['', '']
      - ['read1', 'read1']
      - ['read2', 'read2']
      - ['per_read', 'per_read']
      - ['index1', 'index1']
      - ['index2', 'index2']
      - ['per_index', 'per_index']
    help: 'Location of the UMI(s) to be extracted with fastp.'

  umi_length:
    label: 'umi_length'
    widget: number_field
    step: 1
    help: 'Length of the UMI(s) in the read.'

  umi_base_skip:
    label: 'umi_base_skip'
    widget: number_field
    step: 1
    help: 'Number of bases to skip after the UMI(s) in the read when extracting with fastp.'

  umi_tag:
    label: 'umi_tag'
    widget: text_field
    help: 'Tag detailing where UMIs are present inside the bam/cram file (e.g. RX).'

  bbsplit_fasta_list:
    label: 'bbsplit_fasta_list'
    widget: path_selector
    directory: "<%= ENV.fetch('NF2OOD_DEFAULT_DIRECTORY', ENV.fetch('HOME', '/')) %>"
    favorites:
      - "<%= ENV.fetch('HOME', '/') %>"
    help: 'Path to comma-separated file containing a list of reference genomes to filter reads against with BBSplit. You have to also explicitly set `--tools bbsplit` if you want to use BBSplit.'

  bbsplit_index:
    label: 'bbsplit_index'
    widget: path_selector
    directory: "<%= ENV.fetch('NF2OOD_DEFAULT_DIRECTORY', ENV.fetch('HOME', '/')) %>"
    favorites:
      - "<%= ENV.fetch('HOME', '/') %>"
    help: 'Path to directory or tar.gz archive for pre-built BBSplit index.'

  save_bbsplit_reads:
    label: 'save_bbsplit_reads'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    help: 'If this option is specified, FastQ files split by reference will be saved in the results directory.'

  preprocessing:
    label: 'Preprocessing'
    widget: 'check_box'
    html_options:
      data:
        hide-aligner-when-un-checked: true
        hide-save_mapped-when-un-checked: true
        hide-save_output_as_bam-when-un-checked: true
        hide-use_gatk_spark-when-un-checked: true
        hide-markduplicates_pixel_distance-when-un-checked: true
        hide-sentieon_consensus-when-un-checked: true
    help: 'Configure preprocessing tools'

  aligner:
    label: 'aligner'
    widget: select
    options:
      - ['bwa-mem', 'bwa-mem']
      - ['bwa-mem2', 'bwa-mem2']
      - ['dragmap', 'dragmap']
      - ['sentieon-bwamem', 'sentieon-bwamem']
      - ['parabricks', 'parabricks']
    help: 'Specify aligner to be used to map reads to reference genome.'

  save_mapped:
    label: 'save_mapped'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    help: 'Save mapped files.'

  save_output_as_bam:
    label: 'save_output_as_bam'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    help: 'Saves output from mapping (if `--save_mapped`), Markduplicates & Baserecalibration as BAM file instead of CRAM'

  use_gatk_spark:
    label: 'use_gatk_spark'
    widget: text_field
    help: 'Enable usage of GATK Spark implementation for duplicate marking and/or base quality score recalibration'

  markduplicates_pixel_distance:
    label: 'markduplicates_pixel_distance'
    widget: number_field
    step: 1

  sentieon_consensus:
    label: 'sentieon_consensus'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    help: 'Generate consensus reads with Sentieon dedup rather than choosing one best read.'

  variant_calling:
    label: 'Variant Calling'
    widget: 'check_box'
    html_options:
      data:
        hide-only_paired_variant_calling-when-un-checked: true
        hide-ascat_min_base_qual-when-un-checked: true
        hide-ascat_min_counts-when-un-checked: true
        hide-ascat_min_map_qual-when-un-checked: true
        hide-ascat_ploidy-when-un-checked: true
        hide-ascat_purity-when-un-checked: true
        hide-cf_chrom_len-when-un-checked: true
        hide-cf_coeff-when-un-checked: true
        hide-cf_contamination_adjustment-when-un-checked: true
        hide-cf_contamination-when-un-checked: true
        hide-cf_minqual-when-un-checked: true
        hide-cf_mincov-when-un-checked: true
        hide-cf_ploidy-when-un-checked: true
        hide-cf_window-when-un-checked: true
        hide-cnvkit_reference-when-un-checked: true
        hide-freebayes_filter-when-un-checked: true
        hide-joint_germline-when-un-checked: true
        hide-joint_mutect2-when-un-checked: true
        hide-ignore_soft_clipped_bases-when-un-checked: true
        hide-pon-when-un-checked: true
        hide-pon_tbi-when-un-checked: true
        hide-sentieon_haplotyper_emit_mode-when-un-checked: true
        hide-sentieon_dnascope_emit_mode-when-un-checked: true
        hide-sentieon_dnascope_pcr_indel_model-when-un-checked: true
        hide-gatk_pcr_indel_model-when-un-checked: true
    help: 'Configure variant calling tools'

  only_paired_variant_calling:
    label: 'only_paired_variant_calling'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    help: 'If true, skips germline variant calling for matched normal to tumor sample. Normal samples without matched tumor will still be processed through germline variant calling tools.'

  ascat_min_base_qual:
    label: 'ascat_min_base_qual'
    widget: number_field
    value: 20
    step: 1
    help: 'Overwrite Ascat min base quality required for a read to be counted.'

  ascat_min_counts:
    label: 'ascat_min_counts'
    widget: number_field
    value: 10
    step: 1
    help: 'Overwrite Ascat minimum depth required in the normal for a SNP to be considered.'

  ascat_min_map_qual:
    label: 'ascat_min_map_qual'
    widget: number_field
    value: 35
    step: 1
    help: 'Overwrite Ascat min mapping quality required for a read to be counted.'

  ascat_ploidy:
    label: 'ascat_ploidy'
    widget: number_field
    step: 1
    help: 'Overwrite ASCAT ploidy.'

  ascat_purity:
    label: 'ascat_purity'
    widget: number_field
    step: 1
    help: 'Overwrite ASCAT purity.'

  cf_chrom_len:
    label: 'cf_chrom_len'
    widget: path_selector
    directory: "<%= ENV.fetch('NF2OOD_DEFAULT_DIRECTORY', ENV.fetch('HOME', '/')) %>"
    favorites:
      - "<%= ENV.fetch('HOME', '/') %>"
    help: 'Specify a custom chromosome length file.'

  cf_coeff:
    label: 'cf_coeff'
    widget: number_field
    value: 0.05
    step: 1
    help: 'Overwrite Control-FREEC coefficientOfVariation'

  cf_contamination_adjustment:
    label: 'cf_contamination_adjustment'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    help: 'Overwrite Control-FREEC contaminationAdjustement'

  cf_contamination:
    label: 'cf_contamination'
    widget: number_field
    value: 0
    step: 1
    help: 'Design known contamination value for Control-FREEC'

  cf_minqual:
    label: 'cf_minqual'
    widget: number_field
    value: 0
    step: 1
    help: 'Minimal sequencing quality for a position to be considered in BAF analysis.'

  cf_mincov:
    label: 'cf_mincov'
    widget: number_field
    value: 0
    step: 1
    help: 'Minimal read coverage for a position to be considered in BAF analysis.'

  cf_ploidy:
    label: 'cf_ploidy'
    widget: text_field
    value: '2'
    help: 'Genome ploidy used by ControlFREEC'

  cf_window:
    label: 'cf_window'
    widget: number_field
    step: 1
    help: 'Overwrite Control-FREEC window size.'

  cnvkit_reference:
    label: 'cnvkit_reference'
    widget: path_selector
    directory: "<%= ENV.fetch('NF2OOD_DEFAULT_DIRECTORY', ENV.fetch('HOME', '/')) %>"
    favorites:
      - "<%= ENV.fetch('HOME', '/') %>"
    help: 'Copy-number reference for CNVkit'

  freebayes_filter:
    label: 'freebayes_filter'
    widget: text_field
    value: '30'
    help: 'Filtering expression for vcflib/vcffilter'

  joint_germline:
    label: 'joint_germline'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    help: 'Turn on the joint germline variant calling for GATK haplotypecaller'

  joint_mutect2:
    label: 'joint_mutect2'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    help: 'Runs Mutect2 in joint (multi-sample) mode for better concordance among variant calls of tumor samples from the same patient. Mutect2 outputs will be stored in a subfolder named with patient ID under `variant_calling/mutect2/` folder. Only a single normal sample per patient is allowed. Tumor-only mode is also supported.'

  ignore_soft_clipped_bases:
    label: 'ignore_soft_clipped_bases'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    help: 'Do not analyze soft clipped bases in the reads for GATK Mutect2.'

  pon:
    label: 'pon'
    widget: path_selector
    directory: "<%= ENV.fetch('NF2OOD_DEFAULT_DIRECTORY', ENV.fetch('HOME', '/')) %>"
    favorites:
      - "<%= ENV.fetch('HOME', '/') %>"
    help: 'Panel-of-normals VCF (bgzipped) for GATK Mutect2'

  pon_tbi:
    label: 'pon_tbi'
    widget: path_selector
    directory: "<%= ENV.fetch('NF2OOD_DEFAULT_DIRECTORY', ENV.fetch('HOME', '/')) %>"
    favorites:
      - "<%= ENV.fetch('HOME', '/') %>"
    help: 'Index of PON panel-of-normals VCF.'

  sentieon_haplotyper_emit_mode:
    label: 'sentieon_haplotyper_emit_mode'
    widget: text_field
    value: 'variant'
    help: 'Option for selecting output and emit-mode of Sentieon''s Haplotyper.'

  sentieon_dnascope_emit_mode:
    label: 'sentieon_dnascope_emit_mode'
    widget: text_field
    value: 'variant'
    help: 'Option for selecting output and emit-mode of Sentieon''s Dnascope.'

  sentieon_dnascope_pcr_indel_model:
    label: 'sentieon_dnascope_pcr_indel_model'
    widget: text_field
    value: 'CONSERVATIVE'
    help: 'Option for selecting the PCR indel model used by Sentieon Dnascope.'

  gatk_pcr_indel_model:
    label: 'gatk_pcr_indel_model'
    widget: text_field
    value: 'CONSERVATIVE'

  post_variant_calling:
    label: 'Post variant calling'
    widget: 'check_box'
    html_options:
      data:
        hide-filter_vcfs-when-un-checked: true
        hide-bcftools_filter_criteria-when-un-checked: true
        hide-normalize_vcfs-when-un-checked: true
        hide-snv_consensus_calling-when-un-checked: true
        hide-consensus_min_count-when-un-checked: true
        hide-concatenate_vcfs-when-un-checked: true
        hide-varlociraptor_scenario_tumor_only-when-un-checked: true
        hide-varlociraptor_scenario_somatic-when-un-checked: true
        hide-varlociraptor_scenario_germline-when-un-checked: true
    help: 'Options for tools that run between variant calling and annotation'

  filter_vcfs:
    label: 'filter_vcfs'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    help: 'Enable filtering of VCFs with bcftools view'

  bcftools_filter_criteria:
    label: 'bcftools_filter_criteria'
    widget: text_field
    value: '-f PASS,.'
    help: 'Filter criteria. Uses bcftools view filter options. To customize, follow instructions here: https://samtools.github.io/bcftools/bcftools.html#view'

  normalize_vcfs:
    label: 'normalize_vcfs'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    help: 'Option for normalization of vcf-files.'

  snv_consensus_calling:
    label: 'snv_consensus_calling'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    help: 'Enable consensus calling of multiple VCF files from one sample'

  consensus_min_count:
    label: 'consensus_min_count'
    widget: number_field
    value: 2
    step: 1
    help: 'Minimum number of variant callers calling a variant for consensus results'

  concatenate_vcfs:
    label: 'concatenate_vcfs'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    help: 'Option for concatenating germline vcf-files.'

  varlociraptor_scenario_tumor_only:
    label: 'varlociraptor_scenario_tumor_only'
    widget: text_field
    help: 'Yte compatible scenario file for tumor only samples. Defaults to assets/varlociraptor_tumor_only.yte.yaml'

  varlociraptor_scenario_somatic:
    label: 'varlociraptor_scenario_somatic'
    widget: text_field
    help: 'Yte compatible scenario file for somatic samples. Defaults to assets/varlociraptor_somatic.yte.yaml'

  varlociraptor_scenario_germline:
    label: 'varlociraptor_scenario_germline'
    widget: text_field
    help: 'Yte compatible scenario file for germline samples. Defaults to assets/varlociraptor_germline.yte.yaml'

  annotation:
    label: 'Annotation'
    widget: 'check_box'
    html_options:
      data:
        hide-vep_include_fasta-when-un-checked: true
        hide-vep_condel-when-un-checked: true
        hide-condel_config-when-un-checked: true
        hide-vep_dbnsfp-when-un-checked: true
        hide-dbnsfp-when-un-checked: true
        hide-dbnsfp_tbi-when-un-checked: true
        hide-dbnsfp_consequence-when-un-checked: true
        hide-dbnsfp_fields-when-un-checked: true
        hide-vep_loftee-when-un-checked: true
        hide-vep_mastermind-when-un-checked: true
        hide-mastermind_file-when-un-checked: true
        hide-mastermind_mutations-when-un-checked: true
        hide-mastermind_var_iden-when-un-checked: true
        hide-mastermind_url-when-un-checked: true
        hide-vep_phenotypes-when-un-checked: true
        hide-phenotypes_file-when-un-checked: true
        hide-phenotypes_file_tbi-when-un-checked: true
        hide-phenotypes_include_types-when-un-checked: true
        hide-vep_spliceai-when-un-checked: true
        hide-spliceai_snv-when-un-checked: true
        hide-spliceai_snv_tbi-when-un-checked: true
        hide-spliceai_indel-when-un-checked: true
        hide-spliceai_indel_tbi-when-un-checked: true
        hide-vep_spliceregion-when-un-checked: true
        hide-vep_custom_args-when-un-checked: true
        hide-vep_version-when-un-checked: true
