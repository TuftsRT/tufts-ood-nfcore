---
cluster: "pax"
form_header: |
  > **Saved form values**
  >
  > This app automatically saves your form inputs between sessions.
  >
  > To clear the saved form values for this app, use the [cache reset utility](/pun/sys/cache_reset/?app_slug=nf-core-fetchngs-1-12-0&return_url=/pun/sys/dashboard/batch_connect/sys/nf-core-fetchngs-1-12-0/session_contexts/new).

attributes:
  bc_num_hours:
    label: Number of hours
    widget: number_field
    value: 8
    min: 1
    step: 1
    help: Requested walltime for the launch job.

  bc_email_on_started:
    label: Email when job starts
    widget: check_box
    checked_value: 1
    unchecked_value: 0
    help: Send an email notification when the Open OnDemand launch job starts.

  nextflow_version:
    label: Nextflow version
    widget: select
    options:
      - ["26.04.3", "26.04.3"]
      - ["25.10.3", "25.10.3"]
      - ["25.04.0", "25.04.0"]
    help: Use an older Nextflow version when running previous nf-core pipeline releases.

<%= File.read("/etc/ood/config/apps/dashboard/batch_connect/partials/cpu_partition.yml").indent(2) %>

  num_cores:
    label: Number of cores
    widget: number_field
    value: 4
    min: 1
    step: 1
    help: CPU count used for single-node local execution.

  num_memory:
    label: Amount of memory (GB)
    widget: number_field
    value: 8
    min: 1
    step: 1
    help: Memory requested for single-node local execution.

  executor:
    label: Which Nextflow executor should be used?
    widget: select
    options:
      - ["slurm", "slurm", data-hide-partition: true, data-hide-num-cores: true, data-hide-num-memory: true]
      - ["local", "local"]
    help: |
      With `slurm`, the pipeline uses its configured scheduler profile.
      With `local`, tasks run on the submitted node using a generated config.

  workdir:
    label: Working directory
    widget: path_selector
    required: false
    directory: "/cluster/tufts"
    favorites:
      - "/cluster/tufts"
    help: Directory where the Nextflow launch should run.

  resume:
    label: Resume previous run
    widget: check_box
    checked_value: 1
    unchecked_value: 0
    help: Resume a previous run if a matching Nextflow work directory exists.


  input_output_options:
    label: 'Input/output options'
    widget: 'check_box'
    html_options:
      data:
        hide-input-when-un-checked: true
        hide-ena_metadata_fields-when-un-checked: true
        hide-sample_mapping_fields-when-un-checked: true
        hide-nf_core_pipeline-when-un-checked: true
        hide-nf_core_rnaseq_strandedness-when-un-checked: true
        hide-download_method-when-un-checked: true
        hide-skip_fastq_download-when-un-checked: true
        hide-dbgap_key-when-un-checked: true
        hide-outdir-when-un-checked: true
    help: 'Define where the pipeline should find input data and save output data.'

  input:
    label: 'input'
    required: true
    widget: path_selector
    directory: "<%= ENV.fetch('NF2OOD_DEFAULT_DIRECTORY', ENV.fetch('HOME', '/')) %>"
    favorites:
      - "<%= ENV.fetch('HOME', '/') %>"
    help: 'File containing SRA/ENA/GEO/DDBJ identifiers one per line to download their associated metadata and FastQ files.'

  ena_metadata_fields:
    label: 'ena_metadata_fields'
    widget: text_field
    help: 'Comma-separated list of ENA metadata fields to fetch before downloading data.'

  sample_mapping_fields:
    label: 'sample_mapping_fields'
    widget: text_field
    value: 'experiment_accession,run_accession,sample_accession,experiment_alias,run_alias,sample_alias,experiment_title,sample_title,sample_description'
    help: 'Comma-separated list of ENA metadata fields used to create a separate ''id_mappings.csv'' and ''multiqc_config.yml'' with selected fields that can be used to rename samples in general and in MultiQC.'

  nf_core_pipeline:
    label: 'nf_core_pipeline'
    widget: select
    options:
      - ['', '']
      - ['rnaseq', 'rnaseq']
      - ['atacseq', 'atacseq']
      - ['viralrecon', 'viralrecon']
      - ['taxprofiler', 'taxprofiler']
    help: 'Name of supported nf-core pipeline e.g. ''rnaseq''. A samplesheet for direct use with the pipeline will be created with the appropriate columns.'

  nf_core_rnaseq_strandedness:
    label: 'nf_core_rnaseq_strandedness'
    widget: text_field
    value: 'auto'
    help: 'Value for ''strandedness'' entry added to samplesheet created when using ''--nf_core_pipeline rnaseq''.'

  download_method:
    label: 'download_method'
    widget: select
    options:
      - ['ftp', 'ftp']
      - ['aspera', 'aspera']
      - ['sratools', 'sratools']
    help: 'Method to download FastQ files. Available options are ''aspera'', ''ftp'' or ''sratools''. Default is ''ftp''.'

  skip_fastq_download:
    label: 'skip_fastq_download'
    widget: select
    options:
      - ['false', 'false']
      - ['true', 'true']
    help: 'Only download metadata for public data database ids and don''t download the FastQ files.'

  dbgap_key:
    label: 'dbgap_key'
    widget: path_selector
    directory: "<%= ENV.fetch('NF2OOD_DEFAULT_DIRECTORY', ENV.fetch('HOME', '/')) %>"
    favorites:
      - "<%= ENV.fetch('HOME', '/') %>"
    help: 'dbGaP repository key.'

  outdir:
    label: 'outdir'
    required: true
    widget: path_selector
    directory: "<%= ENV.fetch('NF2OOD_DEFAULT_DIRECTORY', ENV.fetch('HOME', '/')) %>"
    favorites:
      - "<%= ENV.fetch('HOME', '/') %>"
    help: 'The output directory where the results will be saved. You have to use absolute paths to storage on Cloud infrastructure.'

form:
  - bc_num_hours
  - nextflow_version
  - executor
  - partition
  - num_cores
  - num_memory
  - workdir
  - input_output_options
  - input
  - ena_metadata_fields
  - sample_mapping_fields
  - nf_core_pipeline
  - nf_core_rnaseq_strandedness
  - download_method
  - skip_fastq_download
  - dbgap_key
  - outdir
  - resume
  - bc_email_on_started
